OPENAI_API_KEY = "REPLACE_ME"

# Gate (no accounts)
# Example: ["alpha-123","bravo-456"]
PASSCODES_JSON = '["REPLACE_WITH_CODES"]'
ADMIN_EMAIL = "your@email.com"

# LLM controls
ALLOWED_MODELS_JSON = '["gpt-4.1-mini","gpt-4.1"]'
DEFAULT_MODEL = "gpt-4.1-mini"
TEMPERATURE = "0.2"
MAX_OUTPUT_TOKENS = "800"
HARD_TOKEN_BUDGET = "12000"

# Optional email-out
EMAIL_ENABLED = false
EMAIL_PROVIDER = "sendgrid"
SENDGRID_API_KEY = ""
FROM_EMAIL = ""
TO_EMAIL = ""
